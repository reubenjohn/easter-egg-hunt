# Ignore everything by default
*

# Allow traversal into directories
!*/

# Whitelisted file extensions
!*.css
!*.html
!*.jpeg
!*.js
!*.json
!*.lock
!*.md
!*.py
!*.svg
!*.toml
!*.sh
!*.yml

# Top-level config files
!.gitignore
!.mcp.json

# Claude Code - only settings.json
.claude/*
!.claude/settings.json

